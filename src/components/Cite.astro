---
// Inline citation that resolves a literature.yaml id at build time and links to
// the reading list filtered to that one paper (?papers=<id>, the same deep-link
// the applications map uses). A typo'd or missing id fails the build, so prose
// citations can't drift from the data. Author/year come from the entry, never
// hardcoded in the text.
import { getCollection } from "astro:content";
import { toFilterParams } from "./litFilter";

interface Props {
  id: string;
}

const { id } = Astro.props;

const entry = (await getCollection("literature")).find((e) => e.id === id);
if (!entry) {
  throw new Error(`<Cite id="${id}"/>: no literature.yaml entry with that id`);
}

const { authors, year, link } = entry.data;
// "Sterkens, W., et al." -> "Sterkens et al."; single author -> just the surname.
const surname = authors.split(",")[0].trim();
const short = /\bet al\b/.test(authors) ? `${surname} et al.` : surname;

// Base-absolute (reads the configured base) so it survives a repo rename.
const BASE = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const href = `${BASE}literature/${toFilterParams({ ie: [], ml: [], type: [], papers: [id] })}`;
---

<a class="cite" href={href} title={`${authors} (${year}). DOI: ${link}`}>({short}, {year})</a>
